# ── Ollama (local LLM) ──────────────────────────────────────────────────────
# URL of your running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Text-only model (default) – used when USE_VISION_MODEL=false
OLLAMA_MODEL=deepseek-llm:7b

# Vision model – used when USE_VISION_MODEL=true (requires `ollama pull llava:7b`)
OLLAMA_VISION_MODEL=llava:7b

# Set to true to send chart screenshots to a vision model
USE_VISION_MODEL=false

# Timeout in seconds for Ollama requests (7B models can be slow)
OLLAMA_TIMEOUT=120.0

# ── Storage ─────────────────────────────────────────────────────────────────
IMAGE_STORAGE_PATH=data/screenshots
CHART_RENDER_PATH=data/charts

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
